# Docker Environment Variables
# Copy this to .env and fill in your values

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview

# ChromaDB Configuration
CHROMA_DB_PATH=/app/data/chroma
CHROMA_COLLECTION_NAME=kiro_memory

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/kiro.log

# Security
MAX_FILE_SIZE=10485760
ALLOWED_WORKSPACE_PATH=/app/workspace

# Performance
MAX_CONCURRENT_AGENTS=10
AGENT_TIMEOUT=300
RETRY_ATTEMPTS=3
RETRY_DELAY=5

# Development
DEBUG=false
ENABLE_PROFILING=false
